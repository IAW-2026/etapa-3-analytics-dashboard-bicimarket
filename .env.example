# ── Clerk Auth ──────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Rutas de auth ──────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# ── Inter-app URLs ─────────────────────────────────────
BUYER_API_URL=
SELLER_API_URL=
PAYMENTS_API_URL=
SHIPPING_API_URL=

# ── Inter-app tokens ───────────────────────────────────
DASHBOARD_TO_BUYER_SERVICE_TOKEN=
DASHBOARD_TO_SELLER_SERVICE_TOKEN=
DASHBOARD_TO_SHIPPING_SERVICE_TOKEN=
DASHBOARD_TO_PAYMENTS_SERVICE_TOKEN=

# ── AI Copilot — Google Gemini ─────────────────────────
# Obtener API key gratuita en: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
AI_MODEL=gemini-3.1-flash-lite-preview
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=16384
