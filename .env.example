# Clerk compartido por todo BiciMarket
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin

# Token opcional para endpoints S2S que exponga este dashboard.
DASHBOARD_INCOMING_SERVICE_TOKEN=cambiar_por_un_secret_largo_aleatorio

# Buyer
BUYER_API_URL=http://localhost:3001
DASHBOARD_TO_BUYER_SERVICE_TOKEN=
BUYER_ADMIN_RESOURCE_PATH=/api/v1/orders?page=1&limit=20

# Seller
SELLER_API_URL=http://localhost:3002
DASHBOARD_TO_SELLER_SERVICE_TOKEN=
SELLER_ADMIN_RESOURCE_PATH=/api/v1/products?page=1&limit=20

# Shipping
SHIPPING_API_URL=http://localhost:3003
DASHBOARD_TO_SHIPPING_SERVICE_TOKEN=
SHIPPING_ADMIN_RESOURCE_PATH=/api/v1/admin/shipment-groups?page=1&per_page=20

# Payments
PAYMENTS_API_URL=http://localhost:3004
DASHBOARD_TO_PAYMENTS_SERVICE_TOKEN=
PAYMENTS_ADMIN_RESOURCE_PATH=/api/v1/payments?page=1&limit=20
